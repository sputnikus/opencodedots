{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@hueyexe/opencode-ensemble"],
  "model": "openai/gpt-5.3-codex",
  "small_model": "opencode/gpt-5-nano",
  "permission": {
    "plan_exit": "deny",
    "plan_enter": "deny",
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "temperature": 0.1,
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "temperature": 0.1,
      "permission": {
        "plan_exit": "deny",
        "plan_enter": "deny",
      },
    },
    "orchestrator": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "temperature": 0.1,
    },
    "general": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "temperature": 0.1,
      "permission": {
        "plan_exit": "deny",
        "plan_enter": "deny",
      },
    },
    "explore": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0.1,
      "permission": {
        "plan_exit": "deny",
        "plan_enter": "deny",
      },
    },
    "compaction": {
      "model": "openai/gpt-5.1-codex",
      "variant": "medium",
    },
    "title": {
      "model": "opencode/gpt-5-nano",
    },
    "summary": {
      "model": "opencode/gpt-5-nano",
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "temperature": 0.3,
    },
    "librarian": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0.1,
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "temperature": 0.1
    },
  },
  "mcp": {
    "dbeaver": {
      "type": "local",
      "command": ["dbeaver-mcp-server"],
      "enabled": true,
      "environment": {
        "DBEAVER_READ_ONLY": "true",
      },
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y","mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true,
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true,
    },
  },
}
